(function()
    local plr = game:GetService("Players").LocalPlayer
    local rs = game:GetService("ReplicatedStorage")
    local ws = game:GetService("Workspace")
    local guiRoot = game:GetService("CoreGui")
    if not guiRoot then guiRoot = plr.PlayerGui end

    local screen = Instance.new("ScreenGui")
    screen.Name = "ZMG"
    screen.ResetOnSpawn = false
    screen.Parent = guiRoot

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 380, 0, 520)
    frame.Position = UDim2.new(0.5, -190, 0.5, -260)
    frame.BackgroundColor3 = Color3.fromRGB(15,15,25)
    frame.BorderSizePixel = 0
    frame.Active = true
    frame.Draggable = true
    frame.Parent = screen

    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1,0,0,35)
    title.BackgroundColor3 = Color3.fromRGB(60,60,90)
    title.Text = "ZEUS CASH"
    title.TextColor3 = Color3.fromRGB(255,200,0)
    title.TextScaled = true
    title.Font = Enum.Font.GothamBold
    title.Parent = frame

    local close = Instance.new("TextButton")
    close.Size = UDim2.new(0,30,0,30)
    close.Position = UDim2.new(1,-32,0,2)
    close.BackgroundColor3 = Color3.fromRGB(150,20,20)
    close.Text = "X"
    close.TextColor3 = Color3.fromRGB(255,255,255)
    close.Parent = title
    close.MouseButton1Click:Connect(function() screen.Enabled = false end)

    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(1,-10,1,-45)
    scroll.Position = UDim2.new(0,5,0,40)
    scroll.BackgroundTransparency = 1
    scroll.CanvasSize = UDim2.new(0,0,0,600)
    scroll.ScrollBarThickness = 5
    scroll.Parent = frame

    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0,7)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Parent = scroll

    local function makeBtn(text, cb)
        local b = Instance.new("TextButton")
        b.Size = UDim2.new(1,0,0,42)
        b.BackgroundColor3 = Color3.fromRGB(45,45,65)
        b.Text = text
        b.TextColor3 = Color3.fromRGB(255,255,255)
        b.TextScaled = true
        b.Font = Enum.Font.Gotham
        b.BorderSizePixel = 0
        b.Parent = scroll
        b.MouseButton1Click:Connect(cb)
    end

    local function makeLabel(txt)
        local l = Instance.new("TextLabel")
        l.Size = UDim2.new(1,0,0,28)
        l.BackgroundTransparency = 1
        l.Text = txt
        l.TextColor3 = Color3.fromRGB(180,220,255)
        l.TextXAlignment = Enum.TextXAlignment.Left
        l.Font = Enum.Font.GothamBold
        l.TextScaled = true
        l.Parent = scroll
    end

    makeLabel("=== ПРЯМОЙ ЧИТ ===")
    makeBtn("9e14 ДЕНЕГ", function()
        local ls = plr:FindFirstChild("leaderstats")
        if ls then
            for _,v in pairs(ls:GetChildren()) do
                if v:IsA("NumberValue") or v:IsA("IntValue") then
                    v.Value = 9e14
                end
            end
        else
            for _,v in pairs(game:GetDescendants()) do
                if v:IsA("NumberValue") and v.Name:lower():match("coin|cash|money|gem|credit") then
                    v.Value = 9e14
                end
            end
        end
    end)

    makeBtn("ЗАМОРОЗИТЬ БАЛАНС", function()
        local ls = plr:FindFirstChild("leaderstats")
        if ls then
            for _,v in pairs(ls:GetChildren()) do
                if v:IsA("NumberValue") or v:IsA("IntValue") then
                    local last = v.Value
                    v.Changed:Connect(function(new)
                        if new < last then
                            v.Value = last
                        else
                            last = new
                        end
                    end)
                end
            end
        end
    end)

    makeLabel("=== REMOTE ХАК ===")
    makeBtn("ОБНУЛИТЬ ЦЕНЫ (перехват)", function()
        for _,r in pairs(rs:GetDescendants()) do
            if r:IsA("RemoteEvent") and r.Name:lower():match("buy|purchase|shop") then
                local old = r.OnClientEvent
                r.OnClientEvent = function(...)
                    local args = {...}
                    for i,a in pairs(args) do
                        if type(a)=="number" and a>0 and a<1e8 then args[i]=0 end
                    end
                    if old then old(unpack(args)) end
                end
            end
        end
    end)

    makeBtn("СПАМ НАГРАДЫ", function()
        local remotes = {}
        for _,r in pairs(rs:GetDescendants()) do
            if r:IsA("RemoteEvent") and r.Name:lower():match("reward|claim|collect") then
                table.insert(remotes,r)
            end
        end
        spawn(function()
            for i=1,500 do
                for _,r in pairs(remotes) do
                    pcall(function() r:FireServer("claim",math.random(1000,50000)) end)
                end
                task.wait(0.03)
            end
        end)
    end)

    makeLabel("=== АВТОФАРМ ===")
    makeBtn("АВТОКЛИКЕР ПОКУПКИ", function()
        spawn(function()
            while true do
                for _,b in pairs(plr.PlayerGui:GetDescendants()) do
                    if b:IsA("TextButton") and (b.Name:lower():match("buy") or (b.Text and b.Text:lower():match("buy"))) then
                        pcall(function() b:Click() end)
                    end
                end
                task.wait(0.01)
            end
        end)
    end)

    makeBtn("СБОР МОНЕТ С КАРТЫ", function()
        for _,p in pairs(ws:GetDescendants()) do
            if p:IsA("BasePart") and p.Name:lower():match("coin|money|chest") and p.Position then
                pcall(function()
                    plr.Character.HumanoidRootPart.CFrame = CFrame.new(p.Position)
                    task.wait(0.05)
                end)
            end
        end
    end)

    makeLabel("=== РАКЕТНЫЕ ВОЙНЫ ===")
    makeBtn("БЕСКОНЕЧНЫЕ ДЕНЬГИ (RW)", function()
        if _G.PlayerData then _G.PlayerData.Money = 9e99 end
        if shared.PlayerCurrency then shared.PlayerCurrency = 1e308 end
        local pgui = plr.PlayerGui
        local main = pgui:FindFirstChild("MainGUI") or pgui:FindFirstChild("GameGUI")
        if main then
            local moneyLabel = main:FindFirstChild("CurrencyLabel") or main:FindFirstChild("MoneyText")
            if moneyLabel then
                spawn(function()
                    while true do
                        pcall(function() moneyLabel.Text = "∞" end)
                        task.wait(0.5)
                    end
                end)
            end
        end
        plr.Chat:Chat("Бесконечные деньги активированы")
    end)

    makeLabel("=== РАЗБЛОКИРОВКА ===")
    makeBtn("КУПИТЬ ВСЁ ЗА 0", function()
        for _,f in pairs(plr.PlayerGui:GetDescendants()) do
            if f:IsA("Frame") and f:FindFirstChild("BuyButton") then
                local price = f:FindFirstChild("PriceLabel")
                if price and price:IsA("TextLabel") then
                    pcall(function() price.Text = "0" end)
                end
                pcall(function() f.BuyButton:Click() end)
            end
        end
    end)

    makeBtn("ОТКЛЮЧИТЬ ГУИ", function()
        screen.Enabled = false
    end)

    print("GUI загружен. Используй меню.")
end)()
